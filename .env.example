# Riot Games API key — get one at https://developer.riotgames.com
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Your server region: na1 | euw1 | kr | eun1 | br1 | jp1 | la1 | la2 | oc1 | tr1 | ru
REGION=na1

# Cache settings (seconds)
CACHE_TTL_MATCHES=3600
CACHE_TTL_SUMMONER=300
CACHE_TTL_RANKED=120

# SQLite cache file path
CACHE_DB_PATH=lol_cache.db

# Discord bot token (optional — only needed for discord_bot.py)
DISCORD_TOKEN=

# Set to 1 to enable verbose/debug logging
VERBOSE=0
